#!/bin/bash

command_exists () {
  type "$1" &> /dev/null;
}

function _osc52_copy() {
  local data
  data=$(base64 | tr -d '\n')
  local seq
  seq=$(printf '\e]52;c;%s\a' "$data")
  # inside tmux: wrap in passthrough sequence
  if [ -n "$TMUX" ]; then
    seq=$(printf '\ePtmux;\e%s\e\\' "$seq")
  fi
  printf '%s' "$seq" > /dev/tty
}

function cpy() {
  if [ -n "$SSH_TTY" ] || [ -n "$SSH_CONNECTION" ]; then
    _osc52_copy
  elif command_exists pbcopy; then
    pbcopy
  elif command_exists wl-copy; then
    wl-copy
  elif command_exists xclip && [ -n "$DISPLAY" ]; then
    xclip -i -sel c -f | xclip -i -sel p
  else
    _osc52_copy
  fi
}

function pst() {
  if command_exists pbpaste; then
    pbpaste
  elif command_exists wl-paste; then
    wl-paste
  elif command_exists xclip; then
    export DISPLAY="${DISPLAY:-:0}"
    xclip -selection clipboard -o
  else
    echo "pst: no clipboard command found (pbpaste, wl-paste, xclip)" >&2
    return 1
  fi
}
