#!/bin/sh
# gdrive-sync — two-way sync between Google Drive and ~/gdrive
# Reads config from ~/.config/gdrive-sync/config
# Exits silently if not configured (opt-in only)

set -e

CONFIG="$HOME/.config/gdrive-sync/config"

# defaults
GDRIVE_PATH="$HOME/gdrive"
GDRIVE_REMOTE="gdrive"
GDRIVE_FOLDER="sync"

# exit silently if not opted in
[ -f "$CONFIG" ] || exit 0

# This config file is machine-local and gitignored, so ShellCheck cannot resolve it.
# shellcheck source=/dev/null
. "$CONFIG"

# expand tilde in GDRIVE_PATH
eval GDRIVE_PATH="$GDRIVE_PATH"

# ensure local directory exists
mkdir -p "$GDRIVE_PATH"

REMOTE="$GDRIVE_REMOTE:$GDRIVE_FOLDER"

# detect first run — bisync needs --resync to establish baseline
BISYNC_DIR="$HOME/.cache/rclone/bisync"
if [ ! -d "$BISYNC_DIR" ] || [ -z "$(ls -A "$BISYNC_DIR" 2>/dev/null)" ]; then
  echo "gdrive-sync: first run detected, performing initial resync..."
  rclone bisync "$REMOTE" "$GDRIVE_PATH" --resync
else
  rclone bisync "$REMOTE" "$GDRIVE_PATH"
fi

# report conflicts
CONFLICTS=$(find "$GDRIVE_PATH" -name '*.conflict*' -newer "$GDRIVE_PATH" 2>/dev/null || true)
if [ -n "$CONFLICTS" ]; then
  echo "gdrive-sync: conflicts detected — resolve manually:"
  echo "$CONFLICTS"
fi
